# ─── AI vision (optional) ────────────────────────────────────────
# Mistral free tier: https://console.mistral.ai
# Leave empty to use the built-in on-device mock classifier (zero config).
MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-latest

# ─── Shared backend (optional) ───────────────────────────────────
# Supabase: https://supabase.com  (run supabase/schema.sql in the SQL editor)
# Leave empty to use the local file store (zero config).
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Optional: protect POST /api/admin/reset
# ADMIN_TOKEN=
